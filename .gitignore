# Data & logs (heavy / runtime-regenerable)
# data/macro/ là NGOẠI LỆ — commit (nhỏ + khó fetch lại + cần reproduce). Dùng data/*
# thay vì data/ để git vẫn descend vào data/, rồi re-include data/macro/.
data/*
!data/macro/
logs/

# Secrets / local config
.env
proxies.txt

# Local Claude permissions (project-local only)
.claude/settings.local.json
.claude/scheduled_tasks.*

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.coverage
coverage.xml

# OS / editor
Thumbs.db
.DS_Store
.idea/
.vscode/
.bmad-loop/runs/
.bmad-loop/cache/
.bmad-loop/policy.toml

# BMAD tooling (regenerated by installer / `bmad-loop init` — local-only)
.claude/skills/bmad-*/
.agents/
_bmad/config.user.*
# BMAD per-module installer state (top-level _bmad/config.yaml + module-help.csv committed; subdirs are installer/local)
_bmad/_config/
_bmad/bmb/
_bmad/bmm/
_bmad/cis/
_bmad/custom/
_bmad/scripts/
_bmad/tea/

# Crawler Configuration
TARGET_URL=https://finance.vietstock.vn/bao-cao-phan-tich
BASE_URL=https://finance.vietstock.vn

# Paths (relative to project root)
DATA_PATH=data
PDF_PATH=data/pdf
LOG_PATH=logs
CSV_FILE=data/data.csv

# Crawler Settings
RANDOM_DELAY_MIN=3
RANDOM_DELAY_MAX=8
MAX_RETRIES=3
TIMEOUT=30000

# PDF download: false = collect metadata only (much faster, no per-report delay).
# pdf_url is still saved, so PDFs can be fetched in a later pass.
DOWNLOAD_PDF=false

# Proxy Settings
USE_PROXY=false
PROXY_FILE=proxies.txt
